APP_ENV=development
PORT=8080
DATABASE_URL=postgres://millena:millena@127.0.0.1:5432/millena?sslmode=disable
STATIC_DIR=.
CORS_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
DATABASE_MAX_CONNECTIONS=10
SHUTDOWN_TIMEOUT=10s
SESSION_TTL=720h
DEMO_ADMIN_EMAIL=ivan@orka.hr
DEMO_ADMIN_NAME=Ivan
DEMO_ADMIN_PASSWORD=millena-demo
# Set these only in your secure deployment environment. Never commit a real password.
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_NAME=
SUPER_ADMIN_PASSWORD=
AI_PROVIDER=local
AI_REQUEST_TIMEOUT=90s
OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=your-installed-local-model
# Stripe Checkout: use a Stripe test-mode secret key locally. Never commit a real key.
STRIPE_SECRET_KEY=
APP_BASE_URL=http://127.0.0.1:8080
# Transactional e-mail (Gmail requires an App Password, not your Google account password).
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=notifications@example.com
# SMTP_PASSWORD=your-google-app-password
# EMAIL_FROM=notifications@example.com
# Resend SMTP uses SMTP_HOST=smtp.resend.com, SMTP_PORT=465 and SMTP_USERNAME=resend.
EMAIL_FROM_NAME=Millena AI
